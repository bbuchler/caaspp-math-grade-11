{
  "redirects": [
    { "source": "/", "destination": "/course-package/index.html", "permanent": false },
    { "source": "/login", "destination": "/course-package/index.html", "permanent": false },
    { "source": "/dashboard", "destination": "/course-package/teacher-dashboard.html", "permanent": false },
    { "source": "/preview", "destination": "/course-package/preview.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
